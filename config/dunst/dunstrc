[global]
    monitor = 0
    follow = none

    width = 380
    height = 200
    origin = top-right
    offset = 8x36
    scale = 0

    notification_limit = 5
    indicate_hidden = yes
    transparency = 37 
    separator_height = 1
    padding = 14
    horizontal_padding = 16
    text_icon_padding = 12
    frame_width = 1
    frame_color = "#3a0a0d"
    separator_color = frame
    sort = yes

    font = CommitMono Nerd Font Mono 12
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = no

    icon_theme = hicolor
    enable_recursive_icon_lookup = true
    icon_position = left
    min_icon_size = 0
    max_icon_size = 24

    sticky_history = yes
    history_length = 20

    browser = /run/current-system/sw/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 0
    ignore_dbusclose = false
    force_xwayland = false
    force_xinerama = false

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#060204"
    foreground = "#9a9eb0"
    frame_color = "#2a0608"
    timeout = 3

[urgency_normal]
    background = "#060204"
    foreground = "#e6e8f0"
    frame_color = "#3a0a0d"
    highlight = "#ce2c3a"
    timeout = 5

[urgency_critical]
    background = "#0c0204"
    foreground = "#e6e8f0"
    frame_color = "#ce2c3a"
    highlight = "#ce2c3a"
    timeout = 0
